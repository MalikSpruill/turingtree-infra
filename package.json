{
  "name": "turingtree-infra",
  "version": "1.0.0",
  "description": "TuringTree enterprise federated identity and workload infrastructure (AWS CDK TypeScript)",
  "main": "bin/turingtree.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "synth": "cdk synth",
    "diff:engineering": "cdk diff TuringTree-Engineering",
    "diff:analytics": "cdk diff TuringTree-Analytics",
    "deploy:engineering": "cdk deploy TuringTree-Engineering",
    "deploy:analytics": "cdk deploy TuringTree-Analytics",
    "deploy:all": "cdk deploy --all"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "aws-cdk": "2.147.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.4.5"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.614.0",
    "@aws-sdk/lib-dynamodb": "^3.614.0",
    "aws-cdk-lib": "2.147.3",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  }
}
